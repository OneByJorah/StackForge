{
  "title": "StackDeploy Overview",
  "uid": "stackdeploy-overview",
  "version": 1,
  "schemaVersion": 39,
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Healthy"
        },
        {
          "expr": "count(up == 0)",
          "legendFormat": "Unhealthy"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Container Memory Usage",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{container!=\"\"} / 1048576",
          "legendFormat": "{{container}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container!=\"\"}[5m]) * 100",
          "legendFormat": "{{container}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "title": "Container Restarts",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(container_restarts_seconds_total{container!=\"\"}[15m]))",
          "legendFormat": "Restarts"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by(service) (rate({job=~\".+\"}[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
