# =============================================================================
# StackDeploy — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!

# --- Server Configuration ---
# Tailscale IP or local IP of this server
SERVER_IP=REPLACE_WITH_YOUR_TAILSCALE_IP

# --- Obsidian ---
# Host path for the Obsidian vault (default: ./obsidian-vault)
OBSIDIAN_VAULT_PATH=/home/j1admin/ObsidianVault

# --- Honcho Memory API ---
# Auth token for Honcho API (optional)
HONCHO_TOKEN=REPLACE_WITH_YOUR_HONCHO_TOKEN
# PostgreSQL password for Honcho backend (REQUIRED)
HONCHO_DB_PASSWORD=REPLACE_WITH_YOUR_HONCHO_DB_PASSWORD

# --- Camofox Browser ---
# API keys for Camofox browser automation (optional, auto-generated via secrets/)
# CAMOFOX_API_KEY=REPLACE_WITH_CAMOFOX_API_KEY
# CAMOFOX_ADMIN_KEY=REPLACE_WITH_CAMOFOX_ADMIN_KEY

# --- Qdrant Vector DB ---
# API key for Qdrant (optional)
# QDRANT_API_KEY=

# --- Redis ---
# Password for Redis (optional, auto-generated via secrets/)
# REDIS_PASSWORD=

# --- Grafana ---
# Admin credentials for Grafana dashboard
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# --- Optional: Local LLM Add-on ---
# Only used if enabled in docker-compose.yml
# OLLAMA_MODEL=qwen2.5:4b
# OLLAMA_NUM_CPU=4
# OLLAMA_MAX_LOADED_MODELS=1
# OLLAMA_NUM_PARALLEL=2
# MODEL_PATH=/models/Qwen3.5-9B-Coder-Q4_K_M.gguf
# CTX_SIZE=65536
