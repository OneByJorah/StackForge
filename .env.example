# ═══════════════════════════════════════════════════════
# StackForge — Environment Variables
# Copy to .env and fill in your secrets
# ═══════════════════════════════════════════════════════

# ── Server Identity ────────────────────────────────────
SERVER_IP=REPLACE_WITH_YOUR_TAILSCALE_IP

# ── SearXNG ────────────────────────────────────────────
# SVC_SEARXNG_PORT=8080
# SEARXNG_SECRET_KEY=

# ── Qdrant ─────────────────────────────────────────────
# SVC_QDRANT_PORT=6333

# ── Honcho (Memory) ────────────────────────────────────
SVC_HONCHO_PORT=8000
HONCHO_DB_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
HONCHO_TOKEN=REPLACE_WITH_YOUR_HONCHO_API_TOKEN

# ── Honcho LLM Provider (optional) ─────────────────────
# See .env.honcho.example for full configuration
# Honcho needs an OpenAI-compatible provider for LLM features
# LLM_VLLM_API_KEY=
# LLM_VLLM_BASE_URL=https://openrouter.ai/api/v1

# ── CouchDB (Obsidian LiveSync) ────────────────────────
# SVC_COUCHDB_PORT=5984
COUCHDB_ADMIN_USER=admin
COUCHDB_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
COUCHDB_SYNC_USER=obsync
COUCHDB_SYNC_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# ── Syncthing (P2P file sync) ──────────────────────────
# SVC_SYNCTHING_UI_PORT=8384

# ── Selenium Web Automation ────────────────────────────
# SVC_SELENIUM_PORT=4444
# SELENIUM_SHM_SIZE=2g
# SELENIUM_NO_SANDBOX=1
# SELENIUM_VNC_PASSWORD=

# ── Ollama (local LLM — optional) ──────────────────────
# OLLAMA_KEEP_ALIVE=5m
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1

# ── Obsidian Vault ─────────────────────────────────────
# Path on host where Hermes agents write notes
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
